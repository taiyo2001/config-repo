# Force dark appearance (window chrome)
window-theme = dark

# Dark color scheme (iTerm2's classic dark default)
theme = iTerm2 Tango Dark

# Force foreground to white
foreground = #ffffff

# Font for icon support in LazyVim / Neovim
font-family = JetBrainsMono Nerd Font
font-size = 16

# Pass macOS Cmd shortcuts through to the terminal app (e.g. Neovim)
# CSI u modifier: 9 = Cmd, 10 = Cmd+Shift, 11 = Cmd+Alt
# Existing: undo / redo / save / select-all / clipboard
keybind = cmd+z=text:\x1b[122;9u
keybind = cmd+shift+z=text:\x1b[122;10u
keybind = cmd+s=text:\x1b[115;9u
keybind = cmd+a=text:\x1b[97;9u
keybind = cmd+c=text:\x1b[99;9u
keybind = cmd+v=text:\x1b[118;9u
keybind = cmd+x=text:\x1b[120;9u

# VSCode-style shortcuts forwarded to Neovim
keybind = cmd+p=text:\x1b[112;9u             # Quick Open
keybind = cmd+shift+p=text:\x1b[112;10u      # Command Palette
keybind = cmd+b=text:\x1b[98;9u              # Toggle Sidebar
keybind = cmd+f=text:\x1b[102;9u             # Find in file
keybind = cmd+shift+f=text:\x1b[102;10u      # Find in files (global)
keybind = cmd+w=text:\x1b[119;9u             # Close editor (buffer)
keybind = cmd+shift+e=text:\x1b[101;10u      # Focus Explorer
keybind = cmd+shift+g=text:\x1b[103;10u      # Source Control (Diff)
keybind = cmd+shift+o=text:\x1b[111;10u      # Go to Symbol in file
keybind = cmd+period=text:\x1b[46;9u         # Quick Fix / Code Action
keybind = cmd+slash=text:\x1b[47;9u          # Toggle Line Comment
keybind = cmd+grave_accent=text:\x1b[96;9u   # Toggle Terminal
keybind = cmd+comma=text:\x1b[44;9u          # Settings (open config dir)
keybind = cmd+backslash=text:\x1b[92;9u      # Split Editor
